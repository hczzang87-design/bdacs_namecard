# BDACS 명함 온보딩 — 환경 변수 템플릿
# 사용법: cp .env.example .env.local 후 값을 채우세요 (.env.local은 git에 올리지 마세요)

# 신규 입사자에게 전달할 입사 코드 (PIN)
ONBOARDING_PIN=

# Google 스프레드시트 ID (URL의 /d/ 와 /edit 사이 문자열)
GOOGLE_SHEET_ID=

# 서비스 계정 JSON (base64 인코딩 또는 원문 JSON 한 줄)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=

# (선택) Slack 알림·운영용 시트 보기 링크
NEXT_PUBLIC_SHEET_VIEW_URL=
